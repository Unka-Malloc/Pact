        { "label": "Crystal", "extensions": [".cr"] },
        { "label": "D", "extensions": [".d", ".di"] },
        { "label": "Dart", "extensions": [".dart"] },
        { "label": "Dockerfile", "extensions": [".dockerfile"], "fileNames": ["Dockerfile", "Containerfile"] },
        { "label": "Elixir", "extensions": [".ex", ".exs"] },
        { "label": "Elm", "extensions": [".elm"] },
