{
  "schemaVersion": 1,
  "updatedAt": "2026-04-30T00:00:00.000Z",
  "description": "SplitAll import file type dictionary. Add or remove extensions here instead of editing code.",
  "includeUnknownReadableText": true,
  "plainTextFallbackExtension": ".txt",
  "readableTextDetection": {
    "sampleBytes": 4096,
    "maxControlRatio": 0.02
  },
  "kindRoutes": {
    "text": { "mountName": "documentParser", "action": "extractDocument" },
    "email": { "mountName": "documentParser", "action": "extractDocument" },
    "document": { "mountName": "documentParser", "action": "extractDocument" },
    "pdf": { "mountName": "pdfProcessor", "action": "extractDocument" },
    "docx": { "mountName": "documentParser", "action": "extractDocument" },
    "image": { "mountName": "ocr", "action": "extractText" }
  },
  "binarySignatures": [
    { "extension": ".pdf", "bytesHex": "255044462d" },
    { "extension": ".png", "bytesHex": "89504e47" },
    { "extension": ".jpg", "bytesHex": "ffd8ff" },
    { "extension": ".gif", "bytesHex": "47494638" },
    { "extension": ".zip", "bytesHex": "504b0304" }
  ],
  "zipContainerDetectors": [
    { "extension": ".docx", "contains": "word/" },
    { "extension": ".pptx", "contains": "ppt/" },
    { "extension": ".xlsx", "contains": "xl/" }
  ],
  "textSniffingRules": [
    {
      "extension": ".eml",
      "pattern": "^(from|subject|date|message-id|mime-version|content-type):",
      "flags": "im"
    },
    {
      "extension": ".html",
      "pattern": "^\\s*(<!doctype\\s+html|<html|<head|<body)\\b",
      "flags": "i"
    }
  ],
  "groups": [
    {
      "id": "programmingLanguages",
      "label": "Programming language source files",
      "kind": "text",
      "mediaType": "text/plain",
      "route": { "mountName": "documentParser", "action": "extractDocument" },
      "entries": [
        { "label": "Ada", "extensions": [".adb", ".ads", ".ada"] },
        { "label": "Agda", "extensions": [".agda", ".lagda"] },
        { "label": "Arduino", "extensions": [".ino", ".pde"] },
        { "label": "Assembly", "extensions": [".asm", ".s", ".S", ".nasm"] },
        { "label": "Awk", "extensions": [".awk"] },
        { "label": "Bash and POSIX shell", "extensions": [".sh", ".bash", ".bats", ".command", ".ksh", ".zsh"], "fileNames": [".bashrc", ".bash_profile", ".zshrc", ".profile"] },
        { "label": "Batch and command scripts", "extensions": [".bat", ".cmd"] },
        { "label": "C", "extensions": [".c", ".h", ".cats", ".idc"] },
        { "label": "C#", "extensions": [".cs", ".csx"] },
        { "label": "C++", "extensions": [".cc", ".cpp", ".cxx", ".c++", ".hpp", ".hh", ".hxx", ".h++", ".ipp", ".ixx", ".tpp"] },
        { "label": "CMake", "extensions": [".cmake"], "fileNames": ["CMakeLists.txt"] },
        { "label": "COBOL", "extensions": [".cob", ".cbl", ".ccp", ".cobol"] },
