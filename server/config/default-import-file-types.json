        { "label": "XML and schemas", "extensions": [".xml", ".xsl", ".xslt", ".xsd", ".dtd"] },
        { "label": "Zig", "extensions": [".zig", ".zon"] },
        { "label": "Build and CI files", "extensions": [".bazel", ".bzl"], "fileNames": ["BUILD", "BUILD.bazel", "WORKSPACE", "Jenkinsfile", "Justfile", "Procfile", "Earthfile", "Tiltfile", "Snakefile"] }
      ]
    },
    {
      "id": "textDocuments",
      "label": "Readable text documents",
      "kind": "text",
      "mediaType": "text/plain",
      "route": { "mountName": "documentParser", "action": "extractDocument" },
      "entries": [
        { "label": "Plain text", "extensions": [".txt", ".text", ".log", ".out", ".err"] },
        { "label": "Markdown", "extensions": [".md", ".markdown", ".mdown", ".mkd"] },
        { "label": "CSV and TSV", "extensions": [".csv", ".tsv", ".tab"] },
        { "label": "JSON", "extensions": [".json", ".jsonl", ".ndjson", ".geojson", ".har"] },
        { "label": "YAML", "extensions": [".yaml", ".yml"] },
        { "label": "TOML", "extensions": [".toml"] },
        { "label": "INI and env", "extensions": [".ini", ".cfg", ".conf", ".config", ".properties", ".env", ".editorconfig"] },
        { "label": "Subtitles", "extensions": [".srt", ".vtt"] },
        { "label": "Patch and diff", "extensions": [".patch", ".diff"] }
      ]
    },
    {
      "id": "officeDocuments",
      "label": "Office and structured documents",
      "kind": "document",
      "route": { "mountName": "documentParser", "action": "extractDocument" },
      "tika": true,
      "preserveSourceMaterial": true,
      "entries": [
        { "label": "PDF", "extensions": [".pdf"], "kind": "pdf", "mediaType": "application/pdf", "mediaTypes": ["application/pdf"], "route": { "mountName": "pdfProcessor", "action": "extractDocument" }, "normalizedAdapter": "pdf" },
        { "label": "Word", "extensions": [".doc", ".docx", ".dot", ".dotx"], "kind": "docx", "mediaTypes": ["application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/vnd.openxmlformats-officedocument.wordprocessingml.template"] },
        { "label": "PowerPoint", "extensions": [".ppt", ".pptx", ".pps", ".ppsx"], "mediaTypes": ["application/vnd.ms-powerpoint", "application/vnd.openxmlformats-officedocument.presentationml.presentation"], "normalizedAdapter": "presentation" },
        { "label": "Excel", "extensions": [".xls", ".xlsx", ".xlsm"], "mediaTypes": ["application/vnd.ms-excel", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"] },
        { "label": "OpenDocument", "extensions": [".odt", ".ods", ".odp"], "mediaTypes": ["application/vnd.oasis.opendocument.text", "application/vnd.oasis.opendocument.spreadsheet", "application/vnd.oasis.opendocument.presentation"] },
        { "label": "Rich text", "extensions": [".rtf"], "mediaTypes": ["application/rtf"] },
        { "label": "EPUB", "extensions": [".epub"], "mediaType": "application/epub+zip", "mediaTypes": ["application/epub+zip"] }
      ]
    },
    {
      "id": "emailDocuments",
      "label": "Email message files",
      "kind": "email",
      "route": { "mountName": "documentParser", "action": "extractDocument" },
      "tika": true,
      "entries": [
        { "label": "EML", "extensions": [".eml"], "mediaType": "message/rfc822", "mediaTypes": ["message/rfc822"] },
        { "label": "MSG", "extensions": [".msg"], "mediaType": "application/vnd.ms-outlook", "mediaTypes": ["application/vnd.ms-outlook"] },
        { "label": "MBOX", "extensions": [".mbox"], "mediaType": "application/mbox" }
      ]
    },
    {
      "id": "imageDocuments",
      "label": "Images with OCR/caption extraction",
      "kind": "image",
      "route": { "mountName": "ocr", "action": "extractText" },
      "entries": [
        { "label": "PNG", "extensions": [".png"], "mediaType": "image/png" },
        { "label": "JPEG", "extensions": [".jpg", ".jpeg"], "mediaType": "image/jpeg" },
        { "label": "WebP", "extensions": [".webp"], "mediaType": "image/webp" },
        { "label": "GIF", "extensions": [".gif"], "mediaType": "image/gif" },
        { "label": "BMP", "extensions": [".bmp"], "mediaType": "image/bmp" },
        { "label": "TIFF", "extensions": [".tif", ".tiff"], "mediaType": "image/tiff" }
      ]
    },
    {
      "id": "archives",
      "label": "Archives",
      "kind": "archive",
      "mediaType": "application/zip",
      "entries": [
        { "label": "ZIP", "extensions": [".zip"], "mediaTypes": ["application/zip", "application/x-zip-compressed"] }
      ]
    }
  ]
}
