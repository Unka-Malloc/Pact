{
  "schemaVersion": 1,
  "updatedAt": "2026-05-01T00:00:00.000Z",
  "description": "SplitAll knowledge source hydration rules. Edit or override this file instead of hard-coding cloud placeholder behavior.",
  "sampleBytes": 65536,
  "timeoutMs": 60000,
  "zeroByteAsPlaceholder": true,
  "placeholderExtensions": [
    ".gdoc",
    ".gsheet",
    ".gslides",
    ".gdraw",
    ".gform",
    ".gmap",
    ".gsite",
    ".icloud",
    ".cloud",
    ".webloc",
    ".url",
    ".lnk"
  ],
  "placeholderTextSignatures": [
    {
      "id": "google-workspace-shortcut",
      "pattern": "\"url\"\\s*:\\s*\"https://docs\\.google\\.com/",
      "flags": "i"
    },
    {
      "id": "internet-shortcut",
      "pattern": "^\\s*\\[InternetShortcut\\]",
      "flags": "i"
    },
    {
      "id": "onedrive-shortcut",
      "pattern": "https://(1drv\\.ms|onedrive\\.live\\.com|[^\\s/]+\\.sharepoint\\.com)/",
      "flags": "i",
      "extensions": [".url", ".webloc", ".lnk"]
    },
    {
      "id": "macos-webloc",
      "pattern": "https?://",
      "flags": "i",
      "extensions": [".webloc"]
    }
  ]
}
