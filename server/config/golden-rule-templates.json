{
  "protocolVersion": "pact.golden-rule-templates.v1",
  "templates": [
    {
      "templateId": "exact_duplicate_skip_existing",
      "label": "完全一样的知识直接跳过",
      "description": "当新候选知识与已有知识在规范化内容、canonical hash 或证据 hash 上完全一致时，作为历史记录保留以保持透明度，无需重复写入，不进入人工审核队列。",
      "intentKeywords": [
        "完全一样",
        "完全相同",
        "重复",
        "去重",
        "直接跳过",
        "跳过",
        "duplicate",
        "dedupe",
        "exact match",
        "exact duplicate",
        "skip existing"
      ],
      "variables": {
        "packageId": "agent-rule-exact-duplicate-skip-existing",
        "ruleId": "golden_rule_exact_duplicate_skip_existing",
        "label": "完全一样的知识直接跳过",
        "description": "新候选知识与已存在知识完全一致时，无需重复写入并保留透明度记录。",
        "source": "agent-rule-authoring-template"
      },
      "package": {
        "protocolVersion": "pact.golden-rule.v1",
        "schemaVersion": 1,
        "packageId": "{{packageId}}",
        "version": 1,
        "status": "draft",
        "source": "{{source}}",
        "scope": {
          "targets": [
            "knowledgeItem",
            "knowledgeChunk",
            "knowledgeSkill",
            "knowledgeSkillSet"
          ]
        },
        "automationPolicy": {
          "humanReviewIsFinalAuthority": true,
          "agentMayTriage": true,
          "canonicalMutationRequiresReview": true,
          "canaryBeforeActive": true,
          "autoSkipExactDuplicates": true
        },
        "rules": [
          {
            "ruleId": "{{ruleId}}",
            "label": "{{label}}",
            "priority": 120,
            "targetTypes": [
              "knowledgeItem",
              "knowledgeChunk",
              "knowledgeSkill",
              "knowledgeSkillSet"
            ],
            "when": {
              "duplicate": {
                "mode": "exact",
                "scoreAtLeast": 1,
                "existingIdRequired": true,
                "requireMatchedFieldsAny": [
                  "canonicalHash",
                  "normalizedContentHash",
                  "sourceFingerprint",
                  "evidenceHash"
                ]
              },
              "canonicalMutationAbsent": true
            },
            "action": "skip_existing",
            "severity": "low",
            "description": "{{description}}",
            "reason": "候选知识已被判定为完全重复，跳过可避免重复入库和审核队列膨胀。",
            "tags": [
              "deduplication",
              "golden-rule",
              "agent-generated"
            ],
            "effect": {
              "skipWrite": true,
              "skipReviewItem": true,
              "recordAudit": true,
              "keepExistingRevision": true
            },
            "audit": {
              "requiresExistingId": true,
              "requiresMatchedField": true,
              "humanConfirmationRequiredBeforePublish": true
            },
            "examples": [
              {
                "title": "规范化正文 hash 完全一致",
                "candidate": {
                  "deduplication": {
                    "verdict": "exact",
                    "score": 1,
                    "existingId": "knowledge::existing",
                    "sameNormalizedContentHash": true
                  }
                },
                "expectedAction": "skip_existing"
              }
            ]
          }
        ]
      },
      "gate": {
        "expectedDecision": "skip_existing",
        "testScenarios": [
          {
            "scenarioId": "exact-duplicate-knowledge-item",
            "targetType": "knowledgeItem",
            "expectedDecision": "skip_existing",
            "candidate": {
              "evidenceRefs": [
                "evidence::template-check"
              ],
              "deduplication": {
                "verdict": "exact",
                "score": 1,
                "existingId": "knowledge::existing",
                "existingRevision": "rev-1",
                "matchedFields": [
                  "canonicalHash"
                ],
                "sameCanonicalHash": true
              }
            }
          },
          {
            "scenarioId": "exact-duplicate-skill",
            "targetType": "knowledgeSkill",
            "expectedDecision": "skip_existing",
            "candidate": {
              "evidenceRefs": [
                "evidence::skill-template-check"
              ],
              "qualityReport": {
                "passed": true
              },
              "deduplication": {
                "mode": "exact",
                "score": 1,
                "existingSkillId": "skill::existing",
                "sameEvidenceHash": true
              }
            }
          }
        ]
      }
    }
  ]
}
