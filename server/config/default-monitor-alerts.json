{
  "schemaVersion": 1,
  "enabled": true,
  "intervalMs": 5000,
  "heartbeatStaleMs": 15000,
  "queueHeartbeatStaleMs": 60000,
  "recoverInterruptedQueues": true,
  "historyLimit": 200,
  "rules": {
    "supervisorStopped": {
      "enabled": true,
      "severity": "critical",
      "titleTemplate": "后台守护进程离线",
      "messageTemplate": "后台守护进程未运行，PID {{pid}}。请检查 launchd 服务 {{serviceLabel}}。"
    },
    "processNotRunning": {
      "enabled": true,
      "severity": "critical",
      "statuses": ["missing", "stopped", "failed", "exited"],
      "titleTemplate": "{{label}} 未正常运行",
      "messageTemplate": "{{label}} 当前状态为 {{status}}，PID {{pid}}，最近心跳 {{lastHeartbeatAt}}。"
    },
    "processStale": {
      "enabled": true,
      "severity": "warning",
      "statuses": ["stale", "degraded"],
      "titleTemplate": "{{label}} 心跳异常",
      "messageTemplate": "{{label}} 心跳已超过 {{heartbeatAgeSeconds}} 秒，状态 {{status}}。"
    },
    "processRestarted": {
      "enabled": true,
      "severity": "warning",
      "restartCountThreshold": 1,
      "titleTemplate": "{{label}} 已被守护进程重启",
      "messageTemplate": "{{label}} 当前重启次数 {{restartCount}}，PID {{pid}}。"
    },
    "queueInterrupted": {
      "enabled": true,
      "severity": "critical",
      "titleTemplate": "{{queueLabel}} 中断",
      "messageTemplate": "{{queueLabel}} 缺少闭环关闭登记，最近证据 {{evidenceUpdatedAt}}，checkpoint {{checkpointStatus}}，恢复状态 {{recoveryStatus}}。"
    }
  }
}
