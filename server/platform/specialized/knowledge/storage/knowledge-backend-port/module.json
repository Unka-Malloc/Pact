{
  "name": "KnowledgeBackendPort",
  "version": 1,
  "description": "v0.0.1 KnowledgeBasePort for Dify and RAGFlow compatibility through secretRef, policy overlay, receipts, and contract-mode verification.",
  "defaultLoaded": false,
  "protocol": "pact.knowledge-backend-port.v1",
  "components": {
    "knowledgeBackendPort": {
      "path": "./index.mjs",
      "factory": "createKnowledgeBackendPort",
      "packaging": "operator-configured",
      "readOnlyRuntime": false,
      "providers": ["dify", "ragflow"],
      "configFile": "knowledge/knowledge-backends.json"
    }
  },
  "operations": [
    "knowledge.backend.connect",
    "knowledge.space.list",
    "knowledge.search",
    "knowledge.evidence.get",
    "knowledge.export.request",
    "knowledge.permission.request"
  ],
  "verification": {
    "targeted": "npm run server:verify:v001-knowledge-e2e --silent",
    "contractMode": true
  }
}
