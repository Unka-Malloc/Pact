{
  "name": "VectorStore",
  "version": 1,
  "description": "Optional splitall.vector.v1 module for local and external vector database adapters.",
  "defaultLoaded": false,
  "protocol": "splitall.vector.v1",
  "components": {
    "sqliteVec": {
      "path": "./LocalVectorStore/index.mjs",
      "protocol": "splitall.vector.v1",
      "factory": "createLocalVectorStore",
      "providerId": "sqlite-vec",
      "providerType": "sqlite-vec",
      "backend": "sqlite-vec",
      "packaging": "bundled-when-selected",
      "bundled": true,
      "license": "MIT OR Apache",
      "status": "primary"
    },
    "localJsonFallback": {
      "path": "./LocalVectorStore/index.mjs",
      "protocol": "splitall.vector.v1",
      "factory": "createLocalVectorStore",
      "providerId": "builtin:sqlite-json-vector-store",
      "providerType": "offline-fallback",
      "backend": "sqlite-json-fallback",
      "packaging": "built-in-fallback",
      "status": "fallback"
    },
    "lanceDb": {
      "path": "./LanceDB/index.mjs",
      "protocol": "splitall.vector.v1",
      "factory": "createLanceDbVectorStore",
      "providerId": "lancedb",
      "providerType": "lancedb",
      "backend": "lancedb",
      "packaging": "license-gated-optional-runtime",
      "bundled": false,
      "license": "Apache-2.0",
      "status": "optional"
    }
  }
}
