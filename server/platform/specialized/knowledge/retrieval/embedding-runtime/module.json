{
  "name": "EmbeddingRuntime",
  "version": 1,
  "description": "Optional pact.embedding.v1 module with an offline deterministic hashing fallback runtime.",
  "defaultLoaded": false,
  "protocol": "pact.embedding.v1",
  "components": {
    "embeddingRuntime": {
      "path": "./index.mjs",
      "protocol": "pact.embedding.v1",
      "factory": "createEmbeddingRuntime",
      "providerId": "builtin:hashing-vector-runtime",
      "providerType": "offline-fallback",
      "packaging": "optional",
      "license": "project-internal",
      "status": "offline-fallback"
    }
  }
}
