{
  "schemaVersion": 1,
  "name": "RepoOperationsCompatibilityRoute",
  "version": 1,
  "category": "pact-internal-compatibility",
  "compatibilityLayer": "pact-internal-compatibility",
  "compatibilityBoundary": "resource-operation",
  "internalCompatibilityKind": "resource-operation",
  "description": "Built-in compatibility component for common repository operations exposed to agents through Pact MCP and Tool Management.",
  "defaultLoaded": true,
  "protocol": "pact.resource-operation.v1",
  "adapterProtocol": "git-cli.v1+review-provider-plan.v1",
  "maintenanceSkill": "skills/server-mcp/pact-gerrit-mcp-maintainer/SKILL.md",
  "components": {
    "repoOperationRoute": {
      "path": "./index.mjs",
      "factory": "executeRepoOperation",
      "exports": [
        "REPO_OPERATION_IDS",
        "executeRepoOperation"
      ],
      "operationPrefix": "repo.",
      "operations": [
        "repo.status",
        "repo.file.read",
        "repo.tree.list",
        "repo.diff.read",
        "repo.commit.read",
        "repo.file.create",
        "repo.file.update",
        "repo.file.delete",
        "repo.file.move",
        "repo.branch.create",
        "repo.branch.checkout",
        "repo.commit.create",
        "repo.push",
        "repo.proposal.create",
        "repo.review.comment",
        "repo.review.requestChanges",
        "repo.review.approve",
        "repo.merge",
        "repo.submit",
        "repo.rebase",
        "repo.revert",
        "repo.proposal.close",
        "repo.change.abandon",
        "repo.protection.set",
        "repo.webhook.set",
        "repo.member.set"
      ],
      "requiredScopes": [
        "repo:read",
        "repo:write",
        "repo:review",
        "repo:approve",
        "repo:maintain",
        "repo:admin"
      ],
      "maxRisk": "repair_write",
      "auditRequired": true
    }
  },
  "providers": [
    "git",
    "gerrit",
    "github",
    "gitlab"
  ],
  "verification": [
    "npm run server:verify:resource-operations --silent",
    "npm run server:verify:gerrit-mcp --silent",
    "npm run server:verify:mcp-http --silent"
  ]
}
