{
  "schemaVersion": 1,
  "name": "AgentTrafficGatewayIngress",
  "version": 1,
  "category": "agent-client-mcp-compatibility",
  "compatibilityLayer": "agent-client-mcp-compatibility",
  "compatibilityBoundary": "ingress-adapter",
  "clientCompatibilityKind": "traffic-gateway",
  "description": "Optional detachable ingress adapter for placing Pact MCP, HTTP APIs, upload sessions, and client runtime bootstrap behind mature traffic gateways without making the gateway a Pact runtime dependency.",
  "defaultLoaded": false,
  "protocol": "pact.agent-traffic-gateway.v1",
  "adapterProviders": [
    "caddy",
    "nginx"
  ],
  "components": {
    "gatewayIngressProfile": {
      "path": "./index.mjs",
      "factory": "normalizeGatewayIngressProfile",
      "exports": [
        "normalizeGatewayIngressProfile",
        "renderGatewayConfig",
        "renderCaddyConfig",
        "renderNginxConfig",
        "registerGatewayAdapter",
        "listGatewayAdapters",
        "validateGatewayIngressPlan"
      ],
      "routes": [
        "/mcp",
        "/api/mcp",
        "/api/tool-management/v1",
        "/api/agent-workspaces",
        "/api/client-runtime",
        "/api/upload-sessions"
      ],
      "directModeRequired": true,
      "maxRisk": "read_only",
      "auditRequired": false
    }
  },
  "verification": [
    "npm run server:verify:gateway-ingress --silent",
    "npm run server:verify:compatibility-layers --silent"
  ]
}
