{
  "schemaVersion": 1,
  "name": "GerritCodeReviewRoute",
  "version": 1,
  "category": "compatibility",
  "description": "Built-in compatibility component for agent-facing Gerrit code review operations through Pact MCP and Tool Management.",
  "defaultLoaded": true,
  "protocol": "pact.code-review.v1",
  "adapterProtocol": "gerrit.rest.v1+gerrit.git-review-push",
  "maintenanceSkill": "skills/server-mcp/pact-gerrit-mcp-maintainer/SKILL.md",
  "components": {
    "gerritMcpRoute": {
      "path": "./index.mjs",
      "factory": "executeGerritCommonOperation",
      "exports": [
        "GERRIT_ACTIONS",
        "executeGerritCommonOperation",
        "uploadGerritGitChange"
      ],
      "operations": [
        "gerrit.read",
        "gerrit.write",
        "gerrit.maintain",
        "gerrit.git_upload"
      ],
      "tools": [
        "pact.gerrit.read",
        "pact.gerrit.write",
        "pact.gerrit.maintain",
        "pact.gerrit.gitUpload"
      ],
      "requiredScopes": [
        "repo:read",
        "repo:write",
        "repo:maintain"
      ],
      "maxRisk": "repair_write",
      "auditRequired": true
    }
  },
  "runtime": {
    "localTestServer": {
      "gerritVersion": "3.14.0",
      "httpUrl": "http://localhost:18080/",
      "sshUrl": "ssh://localhost:29418",
      "stateRoot": "build/local-data/gerrit",
      "runner": "war-or-docker",
      "preferredRunner": "war",
      "jreRuntimeRoot": "server/platform/modules/knowledge/runtime/jre"
    }
  },
  "verification": [
    "npm run server:gerrit:smoke --silent",
    "npm run server:verify:gerrit-mcp --silent",
    "PACT_VERIFY_GERRIT_LIVE=1 npm run server:verify:gerrit-mcp --silent",
    "npm run server:verify:mcp-http --silent",
    "npm run server:verify:tool-management --silent"
  ]
}
