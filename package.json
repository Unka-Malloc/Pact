ization && npm run server:verify:agent-gateway && npm run server:verify:agent-gateway-compaction && npm run server:verify:agent-sync && npm run server:verify:agent-knowledge-tools && npm run server:verify:tool-management && npm run server:verify:console-auth && npm run server:verify:knowledge-console && npm run server:verify:source-evidence && npm run server:verify:multi-source-connectors && npm run server:verify:operation-policy && npm run server:verify:unified-registration && npm run server:verify:monitor-alerts && npm run server:verify:maintenance-agent && npm run server:verify:maintenance-agent-compaction && npm run server:verify:feature-profiles && npm run server:verify:frontend-feature-registry && npm run server:verify:business-scenarios",
